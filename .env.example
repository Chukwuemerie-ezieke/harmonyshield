# =============================================================================
# HarmonyShield — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Threat Intelligence API Keys
# -----------------------------------------------------------------------------
# Sign up for free accounts to enable live threat feeds:

# AlienVault OTX — https://otx.alienvault.com/ (free account)
# Used for: Real-time threat intelligence feeds on the Threat Monitor page
ALIENVAULT_OTX_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/ (free tier: 1,000 checks/day)
# Used for: IP reputation checking on the Threat Monitor page
ABUSEIPDB_API_KEY=

# NewsAPI — https://newsapi.org/ (free tier: 100 requests/day)
# Used for: Cybersecurity news feed
# Alternative: You can use any RSS feed parser instead
NEWS_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (You must implement auth — see SETUP_GUIDE.md)
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens (generate a strong random string)
# Example: openssl rand -hex 64
JWT_SECRET=

# Secret key for Express session management
# Example: openssl rand -hex 32
SESSION_SECRET=

# Token expiration time (e.g., "7d" for 7 days, "24h" for 24 hours)
JWT_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Email / SMTP (For notifications — see SETUP_GUIDE.md)
# -----------------------------------------------------------------------------
# Configure to enable email alerts for threats, compliance deadlines, etc.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Default "from" address for system emails
EMAIL_FROM=noreply@harmonyshield.ng

# -----------------------------------------------------------------------------
# Database (Optional — defaults to SQLite)
# -----------------------------------------------------------------------------
# For production, consider migrating to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/harmonyshield

# SQLite database file path (default: ./harmonyshield.db)
DATABASE_PATH=./harmonyshield.db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the server runs on (default: 5000)
PORT=5000

# Node environment: "development" or "production"
NODE_ENV=development

# -----------------------------------------------------------------------------
# File Upload (For compliance evidence — see SETUP_GUIDE.md)
# -----------------------------------------------------------------------------
# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=10

# Directory for uploaded files
UPLOAD_DIR=./uploads
